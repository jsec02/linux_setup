#!/usr/bin/env bash

# ================================================================================
# =                                    SETUP                                     =
# ================================================================================

set -euo pipefail

MACHINE=""

CURL="curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors"
CURL_FILE="$CURL --output"

select_machine() {
    while true; do
        read -r -p "Select machine [wsl/pi/kali]: " MACHINE
        case "$MACHINE" in
            wsl | pi | kali) return ;;
            *) echo "Invalid option" >&2 ;;
        esac
    done
}

setup_locale() {
    # Enable en_US.UTF-8 UTF-8
    sudo sed --in-place 's/#en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' "/etc/locale.gen"

    # Compile en_US.UTF-8 UTF-8
    sudo locale-gen

    # Set en_US.UTF-8 UTF-8 as default locale
    echo "LANG=en_US.UTF-8" | sudo tee "/etc/locale.conf"
}

hush_login() {
    touch "$HOME/.hushlogin"
}

update_system() {
    case "$MACHINE" in
        wsl) sudo pacman -Syu --noconfirm ;;
        pi) sudo apt update && sudo apt upgrade --yes ;;
        kali) sudo apt update && sudo apt upgrade --yes ;;
    esac
}

bootstrap_yay() {
    sudo pacman -S --noconfirm git base-devel
    git clone https://aur.archlinux.org/yay.git "/tmp/yay"
    (cd "/tmp/yay" && makepkg --syncdeps --install --noconfirm) # Build arch package from source
    rm --recursive --force "/tmp/yay"
}

bootstrap_parsers() {
    git clone https://github.com/jsec02/parsers.git
}

bootstrap_inventory() {
    case "$MACHINE" in
        wsl) sudo pacman -S --noconfirm git python-pip ;;
        pi) sudo apt install --yes git python3-pip ;;
        kali) sudo apt install --yes git python3-pip ;;
    esac

    pip3 install pyyaml --break-system-packages

    git clone https://github.com/jsec02/linux_inventory.git

    mv linux_inventory inventory
}

install_pip2() {
    $CURL_FILE "/tmp/get-pip.py" \
        https://bootstrap.pypa.io/pip/2.7/get-pip.py
    python2 "/tmp/get-pip.py"
    rm --force "/tmp/get-pip.py"
}

install_packages() {
    case "$MACHINE" in
        # Get list of packages and pass it into corresponding package manager with xargs
        wsl)
            python3 "$HOME/parsers/inventory.py" packages wsl yay | xargs --no-run-if-empty yay -S --noconfirm
            python3 "$HOME/parsers/inventory.py" packages wsl pip3 | xargs --no-run-if-empty pip3 install --break-system-packages
            ;;

        pi)
            python3 "$HOME/parsers/inventory.py" packages pi apt | xargs --no-run-if-empty sudo apt install --yes
            python3 "$HOME/parsers/inventory.py" packages pi pip3 | xargs --no-run-if-empty pip3 install --break-system-packages
            ;;

        kali)
            python3 "$HOME/parsers/inventory.py" packages kali apt | xargs --no-run-if-empty sudo apt install --yes
            install_pip2
            python3 "$HOME/parsers/inventory.py" packages kali pip2 | xargs --no-run-if-empty pip2 install
            python3 "$HOME/parsers/inventory.py" packages kali pip3 | xargs --no-run-if-empty pip3 install --break-system-packages
            ;;
    esac
}

install_neovim() {
    case "$MACHINE" in
        pi)
            # Get latest neovim release, decompress, and extract
            $CURL \
                https://github.com/neovim/neovim/releases/latest/download/nvim-linux-arm64.tar.gz \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/opt

            # Link binary to /usr/local/bin/nvim for PATH access
            sudo ln --symbolic --force "/opt/nvim-linux-arm64/bin/nvim" "/usr/local/bin/nvim"
            ;;

        kali)
            $CURL \
                https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/opt

            sudo ln --symbolic --force "/opt/nvim-linux-x86_64/bin/nvim" "/usr/local/bin/nvim"
            ;;
    esac
}

install_yazi() {
    case "$MACHINE" in
        pi)
            $CURL_FILE "/tmp/yazi-aarch64-unknown-linux-gnu.deb" \
                https://github.com/sxyazi/yazi/releases/latest/download/yazi-aarch64-unknown-linux-gnu.deb

            sudo apt install --yes "/tmp/yazi-aarch64-unknown-linux-gnu.deb"

            rm "/tmp/yazi-aarch64-unknown-linux-gnu.deb"
            ;;
        kali)
            $CURL_FILE "/tmp/yazi-x86_64-unknown-linux-gnu.deb" \
                https://github.com/sxyazi/yazi/releases/latest/download/yazi-x86_64-unknown-linux-gnu.deb

            sudo apt install --yes "/tmp/yazi-x86_64-unknown-linux-gnu.deb"

            rm "/tmp/yazi-x86_64-unknown-linux-gnu.deb"
            ;;
    esac
}

install_atuin() {
    case "$MACHINE" in
        pi)
            $CURL \
                "https://github.com/atuinsh/atuin/releases/latest/download/atuin-aarch64-unknown-linux-gnu.tar.gz" \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/usr/local/bin --strip-components=1 "atuin-aarch64-unknown-linux-gnu/atuin"
            ;;
        kali)
            $CURL \
                "https://github.com/atuinsh/atuin/releases/latest/download/atuin-x86_64-unknown-linux-gnu.tar.gz" \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/usr/local/bin --strip-components=1 "atuin-x86_64-unknown-linux-gnu/atuin"
            ;;
    esac
}

install_zellij() {
    case "$MACHINE" in
        pi)
            $CURL \
                "https://github.com/zellij-org/zellij/releases/latest/download/zellij-aarch64-unknown-linux-musl.tar.gz" \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/usr/local/bin
            ;;
        kali)
            $CURL \
                "https://github.com/zellij-org/zellij/releases/latest/download/zellij-x86_64-unknown-linux-musl.tar.gz" \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/usr/local/bin
            ;;
    esac
}

install_deskflow() {
    local url path

    path=/tmp/deskflow-debian-trixie-x86_64.deb

    url=$(curl --silent https://api.github.com/repos/deskflow/deskflow/releases/latest \
        | jq --raw-output '.assets[]
        | select(.name | test("debian-trixie-x86_64.deb$"))
        | .browser_download_url')

    $CURL_FILE "$path" "$url"

    sudo apt install --yes "$path"

    rm "$path"
}

install_pwndbg() {
    local url path

    path=/tmp/pwndbg_amd64.deb

    url=$(curl --silent https://api.github.com/repos/pwndbg/pwndbg/releases/latest \
        | jq --raw-output '.assets[]
        | select(.name | test ("amd64.deb$"))
        | select (.name | test ("lldb") | not)
        | .browser_download_url')

    $CURL_FILE "$path" "$url"

    sudo apt install --yes "$path"

    rm "$path"
}

install_optional_software() {
    case "$MACHINE" in
        pi)
            install_atuin
            install_neovim
            install_yazi
            install_zellij
            ;;
        kali)
            install_atuin
            install_neovim
            install_yazi
            install_zellij
            install_deskflow
            install_pwndbg
            ;;
    esac
}

prompt_for_secrets() {
    export RESTIC_REPOSITORY RESTIC_PASSWORD B2_ACCOUNT_ID B2_ACCOUNT_KEY

    while true; do
        read -r -p "Enter Restic repository: " RESTIC_REPOSITORY
        read -r -s -p "Enter Restic password: " RESTIC_PASSWORD && echo
        read -r -p "Enter B2 account ID: " B2_ACCOUNT_ID
        read -r -s -p "Enter B2 account key: " B2_ACCOUNT_KEY && echo

        # Exit loop on valid credentials
        restic snapshots &>/dev/null && return

        echo "Invalid credentials" >&2
    done
}

restore_from_restic() {
    # Parser should return "ssh" tag first for passwordless auth
    while read -r sudo tag; do
        local cmd="restic"
        [[ "$sudo" == "true" ]] && cmd="sudo --preserve-env restic"

        # </dev/tty: allows ssh interactive prompts to reach the terminal through the while read loop
        # --ownership-by-name restores ownership by username rather than UID. This removes the fragility
        # of the previous installations master UID needing to match the new installations master UID
        $cmd restore latest --host "$MACHINE" --tag "$tag" --target / --ownership-by-name </dev/tty

        # Sudo restores write cache files as root
        # Fix ownership before the next non-sudo tag
        [[ "$cmd" != "restic" ]] && sudo chown -R "$USER:$USER" "$HOME/.cache/restic"

    done < <(python3 "$HOME/parsers/inventory.py" tags "$MACHINE")

    # Fix cache permissions after sudo restores
    sudo chown -R "$USER:$USER" "$HOME/.cache/restic"
}

run_linksync() {
    # Linksync depends on the machines hostname being either wsl, pi, or kali
    # On the first boot of wsl, the hostname is not set correctly
    # so when setting up wsl, we need to restart and run linksync manually
    "$HOME/bash/scripts/linksync"
}

create_restic_repo() {
    restic init --repo "$HOME/restic"
}

setup_metasploit() {
    sudo systemctl enable --now postgresql
    sudo msfdb init
}

setup_bloodhound() {
    # The user needs to manually visit http://localhost:7474,
    # change the password for neo4j, and update /etc/bhapi/bhapi.json
    sudo bloodhound-setup
}

setup_dashboard() {
    sudo docker run --detach --name homepage \
        --env HOMEPAGE_ALLOWED_HOSTS=10.0.0.30:3000 \
        --env PUID=1000 \
        --env PGID=1000 \
        --publish 3000:3000 \
        --volume "$HOME/.config/homepage:/app/config" \
        --volume "/var/run/docker.sock:/var/run/docker.sock:ro" \
        --dns 10.0.0.30 \
        --dns 1.1.1.1 \
        --restart unless-stopped \
        ghcr.io/gethomepage/homepage:latest
}

setup_tldr() {
    tldr --update
}

decompress_rockyou() {
    [[ -f "/usr/share/wordlists/rockyou.txt.gz" ]] \
        && sudo gzip --decompress "/usr/share/wordlists/rockyou.txt.gz"
}

setup_uv() {
    $CURL https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH" # Add uv to PATH for script duration
}

setup_venvs() {
    mkdir --parents "$HOME/venvs"

    local projects=(
        "alien_invasion" "data_visualization" "fish_tank" "infosec_forum"
        "ping" "port_scanner" "riven_sniper" "wfm"
    )

    # Loop over projects array, if directory exists on system, create virtual environment with corresponding requirements.txt file
    for project in "${projects[@]}"; do
        [[ -d "$HOME/python/projects/$project" ]] || continue
        uv venv "$HOME/venvs/$project" --python 3.13 # Pin version for pre-built wheels
        uv pip install --requirement "$HOME/python/projects/$project/requirements.txt" \
            --python "$HOME/venvs/$project/bin/python3"
    done
}

setup_zsa_qmk_firmware() {
    # qmk setup may warn about missing avr tools (avr-gcc, avrdude, dfu-programmer)
    # these are only needed for AVR-based keyboards; the Voyager uses ARM (arm-none-eabi-gcc)

    git clone https://github.com/zsa/qmk_firmware.git "$HOME/zsa_qmk_firmware"
    ln --symbolic "$HOME/qgmlwy" "$HOME/zsa_qmk_firmware/keyboards/zsa/voyager/keymaps/qgmlwy"

    # Pull in nested dependencies declared in .gitmodules
    (cd "$HOME/zsa_qmk_firmware" && git submodule update --init --recursive)

    # Setup virtual environment
    uv venv "$HOME/venvs/qmk"
    source "$HOME/venvs/qmk/bin/activate"
    uv pip install qmk
    qmk setup --home "$HOME/zsa_qmk_firmware"
    deactivate
}

setup_mariadb() {
    sudo mariadb-install-db --user=mysql --basedir=/usr --datadir=/var/lib/mysql
    sudo systemctl enable --now mariadb
    sudo mariadb --user=root --execute "CREATE USER 'master'@'localhost' IDENTIFIED BY ''"
    sudo mariadb --user=root --execute "GRANT ALL PRIVILEGES ON *.* TO 'master'@'localhost'"
}

setup_jellyfin() {
    sudo mkdir --parents /srv/jellyfin/{movies,shows,educational}
    sudo chown --recursive "$USER:$USER" "/srv/jellyfin"
    sudo mount --options remount,size=3G /tmp # Installer needs >= 2gb free space in /tmp
    $CURL https://repo.jellyfin.org/install-debuntu.sh | sudo bash
}

setup_navidrome() {
    local path url

    sudo mkdir --parents "/srv/navidrome/music"
    sudo chown -R "$USER:$USER" "/srv/navidrome"

    path="/tmp/navidrome_linux_arm64.deb"

    url=$(curl --silent https://api.github.com/repos/navidrome/navidrome/releases/latest \
        | jq --raw-output '.assets[]
        | select(.name | test ("linux_arm64.deb$"))
        | .browser_download_url')

    $CURL_FILE "$path" "$url"

    sudo apt install --yes "$path"

    rm "$path"

    sudo systemctl enable --now navidrome
}

setup_services() {
    sudo systemctl enable --now nftables

    case "$MACHINE" in
        wsl)
            sudo systemctl enable --now sshd
            setup_mariadb
            ;;
        pi)
            sudo systemctl enable --now ssh
            sudo systemctl enable --now riven-sniper
            sudo systemctl enable --now qbittorrent-nox
            sudo systemctl enable --now glances-web
            $CURL https://install.pi-hole.net | bash
            setup_jellyfin
            setup_navidrome
            ;;
        kali)
            sudo systemctl enable --now ssh
            ;;
    esac
}

disable_wifi_powersaving() {
    echo -e "[connection]\nwifi.powersave = 2" \
        | sudo tee "/etc/NetworkManager/conf.d/disable-wifi-powersaving.conf"
}

setup_wsl() {
    setup_locale
    update_system
    bootstrap_yay
    bootstrap_parsers
    bootstrap_inventory
    install_packages
    prompt_for_secrets
    restore_from_restic
    setup_tldr
    setup_uv
    setup_venvs
    setup_zsa_qmk_firmware
    setup_services
}

setup_pi() {
    hush_login
    update_system
    bootstrap_parsers
    bootstrap_inventory
    install_packages
    install_optional_software
    prompt_for_secrets
    restore_from_restic
    run_linksync
    create_restic_repo
    setup_dashboard
    setup_tldr
    setup_uv
    setup_venvs
    setup_services
}

setup_kali() {
    hush_login
    update_system
    bootstrap_parsers
    bootstrap_inventory
    install_packages
    install_optional_software
    prompt_for_secrets
    restore_from_restic
    run_linksync
    setup_metasploit
    setup_bloodhound
    setup_tldr
    decompress_rockyou
    setup_services
    disable_wifi_powersaving
}

main() {
    if ((UID == 0)); then
        echo "Do not run this script as root" >&2
        exit 1
    fi

    select_machine

    # Grant wheel group passwordless sudo
    echo "%wheel ALL=(ALL:ALL) NOPASSWD: ALL" | sudo tee "/etc/sudoers.d/nopasswd"

    case "$MACHINE" in
        wsl) setup_wsl ;;
        pi) setup_pi ;;
        kali) setup_kali ;;
    esac

    # Revoke wheel group passwordless sudo
    sudo rm "/etc/sudoers.d/nopasswd"

    if command -v zsh >/dev/null; then
        chsh --shell "/usr/bin/zsh"
        exec zsh
    fi
}

main "$@"
